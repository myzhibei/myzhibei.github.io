{% capture footer_contents %}
  &copy; Copyright {{ site.time | date: '%Y' }}
  {{ site.first_name }}
  {{ site.middle_name }}
  {{ site.last_name }}. {{ site.footer_text }}
  {% assign rss_enabled = false %}
  {% for social in site.data.socials %}
    {% if social[0] == 'rss_icon' and social[1] == true %}
      {% assign rss_enabled = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% if rss_enabled %}
    <span style="margin-left: 12px;">
      <a href="{{ site.baseurl }}/feed.xml" title="RSS Feed" style="color: inherit; text-decoration: none;">
        <i class="fa-solid fa-square-rss"></i>
      </a>
    </span>
  {% endif %}
  {% if site.impressum_path %}
    <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
  {% endif %}
  {% if site.last_updated %}
    Last updated: {{ 'now' | date: '%B %d, %Y' }}.
  {% endif %}
  {% if page.url != '/' %}
    <span id="busuanzi_container_site_pv" style="margin-left: 12px;">
      <i class="fa-solid fa-eye"></i> Total Visits: <span id="busuanzi_value_site_pv"></span>
    </span>
  {% endif %}
{% endcapture %}

{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      {{ footer_contents }}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include newsletter.liquid %}
    {% endif %}

    <div class="container">
      {{ footer_contents }}
    </div>
  </footer>
{% endif %}
